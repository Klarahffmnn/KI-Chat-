<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>CiteFlow Desktop - Prototyp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/lucide-static@0.321.0/font/lucide.min.css" rel="stylesheet">
    <style>
        body { overflow: hidden; height: 100vh; width: 100vw; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-white">
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        function CiteFlowApp() {
            const [activeTab, setActiveTab] = useState('KI Chat');

            // Die Menüpunkte exakt von deiner Skizze
            const menuItems = [
                { id: 'Suchfeld', icon: 'lucide-search' },
                { id: 'Dashboard', icon: 'lucide-layout-dashboard' },
                { id: 'Bibliothek', icon: 'lucide-library' },
                { id: 'PDF-Reader', icon: 'lucide-file-text' },
                { id: 'Zitieren', icon: 'lucide-quote' },
                { id: 'KI Chat', icon: 'lucide-message-square' },
                { id: 'Aufgaben', icon: 'lucide-check-square' }
            ];

            return (
                <div className="flex h-screen w-screen border-4 border-slate-800 rounded-lg overflow-hidden shadow-2xl bg-white">
                    
                    {/* LINKE SEITENLEISTE (Navigation) */}
                    <div className="w-44 border-r-2 border-slate-300 flex flex-col bg-white">
                        {menuItems.map((item) => (
                            <button 
                                key={item.id}
                                onClick={() => setActiveTab(item.id)}
                                className={`flex items-center gap-2 px-3 py-3 border-b border-slate-200 text-xs font-medium transition-colors
                                    ${activeTab === item.id ? 'bg-slate-200 text-black' : 'text-slate-600 hover:bg-slate-50'}`}
                            >
                                <i className={`${item.icon} w-4 h-4`}></i> {item.id}
                            </button>
                        ))}
                        
                        <div className="mt-auto p-3 border-t-2 border-slate-300 italic text-[10px]">
                            <span className="border rounded-full px-2 py-0.5 border-slate-800">Onboarding</span>
                        </div>
                    </div>

                    {/* HAUPTBEREICH (KI Chat Fenster) */}
                    <div className="flex-1 flex flex-col relative bg-white">
                        
                        {/* Chat Header */}
                        <div className="p-4 border-b-2 border-slate-300 flex justify-between items-start">
                            <div className="flex flex-col gap-2">
                                <h2 className="text-xl font-bold italic underline">KI - Chat</h2>
                                <div className="text-xs flex gap-2">
                                    <span>[i] durchsucht durch deine Quelle.. (x)</span>
                                    <span className="ml-4 font-bold border px-1">[DE / EN]</span>
                                </div>
                                <div className="text-xs">
                                    Filter: [aktuelle Sammlung v] <span className="ml-4 border px-1">[Lang v]</span>
                                </div>
                            </div>
                        </div>

                        {/* Chat Inhalt (Simulation der Skizze) */}
                        <div className="flex-1 p-6 space-y-8 overflow-y-auto no-scrollbar">
                            
                            {/* User Frage */}
                            <div className="flex justify-end">
                                <span className="border-2 border-slate-800 px-3 py-1 rounded text-sm font-medium">
                                    [user: was sagt Autor X ... ?]
                                </span>
                            </div>

                            {/* KI Antwort mit Warnung */}
                            <div className="space-y-4">
                                <p className="text-sm">AI: Autor X definiert das Thema als ...</p>
                                
                                <div className="flex items-center gap-2 text-red-600 font-bold text-sm bg-red-50 p-2 border-2 border-red-600 rounded">
                                    <i className="lucide-alert-triangle w-4 h-4"></i>
                                    ⚠ Widerspruch zu Autor Y erkannt!
                                </div>

                                {/* Confidence Balken */}
                                <div className="pt-4 flex items-center gap-4">
                                    <span className="text-sm font-bold italic">confidence</span>
                                    <div className="w-64 h-6 border-2 border-slate-800 relative bg-slate-100">
                                        <div className="bg-slate-600 h-full w-[95%]"></div>
                                        <span className="absolute right-[-40px] top-0 text-sm font-bold italic">95% (i)</span>
                                    </div>
                                </div>

                                {/* Quellen Zeile */}
                                <div className="flex items-center gap-4 py-2">
                                    <span className="text-sm font-bold italic">Quellen:</span>
                                    <span className="border-2 border-slate-800 px-2 py-1 text-xs flex items-center gap-1">
                                        [Müller, S. 12 (👁️)]
                                    </span>
                                    <span className="border-2 border-slate-800 px-2 py-1 text-xs flex items-center gap-1">
                                        [Weber, S. 5 (👁️)]
                                    </span>
                                </div>

                                {/* Action Buttons */}
                                <div className="flex gap-4 text-sm font-bold italic">
                                    <span>(💾) (📄) (zitat)</span>
                                    <span className="border px-2">[verknüpfen mit kap. 1 v]</span>
                                    <span>(vx)</span>
                                </div>
                            </div>
                        </div>

                        {/* Eingabebereich unten */}
                        <div className="p-4 border-t-2 border-slate-300 space-y-4">
                            <div className="flex gap-4">
                                <button className="border-2 border-slate-800 px-2 py-1 text-xs font-bold">[Fasse zusammen]</button>
                                <button className="border-2 border-slate-800 px-2 py-1 text-xs font-bold">[Gegenargumente]</button>
                                <button className="border-2 border-slate-800 px-2 py-1 text-xs font-bold">[Quellenvergleich]</button>
                            </div>
                            
                            <div className="flex items-center gap-2 border-b-2 border-slate-800 pb-1">
                                <span className="italic text-sm">Frag mich etwas ...</span>
                                <span className="ml-auto text-sm italic">(@) (>)</span>
                            </div>
                            
                            <div className="text-center italic text-xs border border-slate-400 py-1">
                                [ @ chatverlauf durchsuchen ]
                            </div>
                        </div>
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<CiteFlowApp />);
    </script>
</body>
</html>
