/* ── Chat Message ── */
function ChatMessage({ msg, onFeedback, onSourceCheck, citStyle }) {
  const [copied, setCopied] = useState(false);
  const [saved, setSaved]   = useState(false);
  const [showCite, setShowCite] = useState(false);

  if (msg.role === "user") {
    return (
      <div className="fade-in" style={{ display:"flex", justifyContent:"flex-end", marginBottom:12 }}>
        <div style={{ maxWidth:"80%", background:"#2563eb", color:"#fff",
          fontSize:13, borderRadius:"16px 16px 4px 16px", padding:"10px 14px", lineHeight:1.6 }}>
          {msg.text}
        </div>
      </div>
    );
  }
  if (msg.isIntro) {
    return (
      <div className="fade-in" style={{ display:"flex", alignItems:"flex-start", gap:8, marginBottom:16 }}>
        <div style={{ width:28, height:28, borderRadius:"50%", background:"#dbeafe",
          display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, marginTop:2 }}>
          <IcBookOpen size={14} color="#2563eb" />
        </div>
        <div style={{ background:"#eff6ff", border:"1px solid #dbeafe",
          borderRadius:"16px 16px 16px 4px", padding:"12px 14px", flex:1 }}>
          <div style={{ display:"flex", alignItems:"center", gap:6, marginBottom:5 }}>
            <IcInfo size={12} color="#3b82f6" />
            <span style={{ fontSize:11, fontWeight:500, color:"#1d4ed8" }}>Nur lokale PDFs – keine KI-Halluzination aus dem Internet</span>
          </div>
          <p style={{ fontSize:13, color:"#1e40af", lineHeight:1.6 }}>{msg.text}</p>
        </div>
      </div>
    );
  }

  const warnBg   = msg.confidenceLevel==="low" ? "#fef2f2" : "#fffbeb";
  const warnBd   = msg.confidenceLevel==="low" ? "#fecaca" : "#fde68a";
  const warnCol  = msg.confidenceLevel==="low" ? "#991b1b" : "#92400e";

  return (
    <div className="fade-in" style={{ display:"flex", alignItems:"flex-start", gap:8, marginBottom:16 }}>
      <div style={{ width:28, height:28, borderRadius:"50%", background:"#f1f5f9",
        display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, marginTop:2 }}>
        <IcLayers size={14} color="#64748b" />
      </div>
      <div style={{ flex:1, minWidth:0 }}>
        <div style={{ background:"#fff", border:"1px solid #e2e8f0",
          borderRadius:"16px 16px 16px 4px", padding:"12px 14px",
          boxShadow:"0 1px 4px rgba(0,0,0,0.05)" }}>
          <p style={{ fontSize:13, color:"#1e293b", lineHeight:1.65 }}>{msg.text}</p>

          {/* Confidence */}
          {msg.confidence != null &&
            <ConfidenceBar level={msg.confidenceLevel} label={msg.confidenceLabel}
              value={msg.confidence} matchCount={msg.sources?.length*2||0} />}

          {/* Conflict warning */}
          {msg.conflictWarning &&
            <div style={{ marginTop:8, display:"flex", gap:6, fontSize:11,
              background:"#fff7ed", border:"1px solid #fed7aa", borderRadius:8,
              padding:"8px 10px", color:"#9a3412", alignItems:"flex-start" }}>
              <IcAlert size={12} color="#ea580c" style={{ flexShrink:0, marginTop:1 }} />
              <span>{msg.conflictMsg}</span>
            </div>}

          {/* General warning */}
          {msg.warning && !msg.conflictWarning &&
            <div style={{ marginTop:8, display:"flex", gap:6, fontSize:11,
              background:warnBg, border:`1px solid ${warnBd}`, borderRadius:8,
              padding:"8px 10px", color:warnCol, alignItems:"flex-start" }}>
              <IcAlert size={12} color="currentColor" style={{ flexShrink:0, marginTop:1 }} />
              <span>{msg.warning}</span>
            </div>}

          {/* Sources */}
          {msg.sources?.length > 0 &&
            <div style={{ marginTop:10 }}>
              <p style={{ fontSize:11, color:"#94a3b8", marginBottom:6 }}>
                {msg.sourceCount==="multi" ? "Mehrere Quellen belegt:" : "Einzelbeleg:"}
              </p>
              <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>
                {msg.sources.map((src,i) =>
                  <SourceBadge key={i} source={src} onCheck={onSourceCheck} style={citStyle} />)}
              </div>
            </div>}

          {/* Add source CTA */}
          {msg.confidenceLevel==="low" &&
            <button style={{ marginTop:8, fontSize:11, color:"#2563eb", background:"none",
              border:"none", cursor:"pointer", display:"flex", alignItems:"center", gap:4, fontFamily:"inherit" }}>
              <IcFile size={11} color="#2563eb" /> Quelle zur Bibliothek hinzufügen
            </button>}

          {/* Cite panel */}
          {showCite && msg.sources?.length > 0 &&
            <div style={{ marginTop:10, background:"#f8fafc", border:"1px solid #e2e8f0",
              borderRadius:8, padding:"10px 12px" }}>
              <p style={{ fontSize:11, color:"#64748b", marginBottom:6, fontWeight:500 }}>Zitation generieren:</p>
              <div style={{ display:"flex", flexDirection:"column", gap:5 }}>
                {msg.sources.map((src,i) => {
                  const apa = `${src.author} (${src.year}). ${src.title}. S. ${src.page}.`;
                  const fn  = `${src.author}, ${src.title}, ${src.year}, S. ${src.page}.`;
                  return (
                    <div key={i} style={{ fontSize:11, color:"#374151",
                      background:"#fff", border:"1px solid #e2e8f0",
                      borderRadius:6, padding:"6px 10px" }}>
                      <span style={{ color:"#94a3b8" }}>APA: </span>{apa}<br/>
                      <span style={{ color:"#94a3b8" }}>Fußnote: </span>{fn}
                    </div>
                  );
                })}
              </div>
            </div>}
        </div>

        {/* Action row */}
        <div style={{ display:"flex", alignItems:"center", gap:4, marginTop:6, paddingLeft:4, flexWrap:"wrap" }}>
          <button onClick={() => { navigator.clipboard?.writeText(msg.text).catch(()=>{}); setCopied(true); setTimeout(()=>setCopied(false),1500); }}
            style={{ display:"flex", alignItems:"center", gap:4, fontSize:11,
              color:"#94a3b8", padding:"4px 8px", borderRadius:6, border:"none",
              background:"transparent", cursor:"pointer", fontFamily:"inherit" }}>
            {copied ? <IcCheck size={12} color="#10b981" /> : <IcCopy size={12} color="currentColor" />}
            {copied ? <span style={{color:"#10b981"}}>Kopiert</span> : "Kopieren"}
          </button>
          <button onClick={() => setSaved(s=>!s)}
            style={{ display:"flex", alignItems:"center", gap:4, fontSize:11,
              color: saved?"#2563eb":"#94a3b8", padding:"4px 8px", borderRadius:6, border:"none",
              background:"transparent", cursor:"pointer", fontFamily:"inherit" }}>
            <IcBookmark size={12} color={saved?"#2563eb":"currentColor"} />
            {saved ? "Gespeichert" : "Speichern"}
          </button>
          {msg.sources?.length > 0 &&
            <button onClick={() => setShowCite(s=>!s)}
              style={{ display:"flex", alignItems:"center", gap:4, fontSize:11,
                color: showCite?"#2563eb":"#94a3b8", padding:"4px 8px", borderRadius:6, border:"none",
                background:"transparent", cursor:"pointer", fontFamily:"inherit" }}>
              <IcQuote size={12} color={showCite?"#2563eb":"currentColor"} />
              Zitation
            </button>}
          <button style={{ display:"flex", alignItems:"center", gap:4, fontSize:11,
            color:"#94a3b8", padding:"4px 8px", borderRadius:6, border:"none",
            background:"transparent", cursor:"pointer", fontFamily:"inherit" }}>
            <IcLink size={12} color="currentColor" /> Kapitel verknüpfen
          </button>
          <div style={{ display:"flex", gap:2, marginLeft:"auto" }}>
            <button onClick={() => onFeedback(msg.id,"up")}
              style={{ padding:6, borderRadius:6, border:"none", background:"transparent", cursor:"pointer" }}>
              <IcThumbUp size={12} color={msg.feedback==="up"?"#10b981":"#cbd5e1"} />
            </button>
            <button onClick={() => onFeedback(msg.id,"down")}
              style={{ padding:6, borderRadius:6, border:"none", background:"transparent", cursor:"pointer" }}>
              <IcThumbDown size={12} color={msg.feedback==="down"?"#ef4444":"#cbd5e1"} />
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

/* ── Placeholder page ── */
function PlaceholderPage({ label, Icon }) {
  return (
    <div style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center",
      justifyContent:"center", gap:12, color:"#94a3b8", padding:40 }}>
      <Icon size={40} color="#cbd5e1" />
      <p style={{ fontSize:16, fontWeight:500, color:"#64748b" }}>{label}</p>
      <p style={{ fontSize:13, textAlign:"center", maxWidth:260, lineHeight:1.6 }}>
        Dieser Bereich ist in Phase 3 (High-Fidelity MVP) vorgesehen.
      </p>
    </div>
  );
}

/* ── KI Chat ── */
function KIChat() {
  const [messages, setMessages]       = useState(INIT_MSGS);
  const [input, setInput]             = useState("");
  const [scope, setScope]             = useState(SCOPES[0]);
  const [scopeOpen, setScopeOpen]     = useState(false);
  const [modalSrc, setModalSrc]       = useState(null);
  const [isTyping, setIsTyping]       = useState(false);
  const [lang, setLang]               = useState("de");
  const [ansLen, setAnsLen]           = useState("normal");
  const [citStyle, setCitStyle]       = useState("apa");
  const [histSearch, setHistSearch]   = useState("");
  const [showSearch, setShowSearch]   = useState(false);
  const bottomRef = useRef(null);
  const scopeRef  = useRef(null);

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior:"smooth" }); }, [messages, isTyping]);

  useEffect(() => {
    const h = (e) => { if (scopeRef.current && !scopeRef.current.contains(e.target)) setScopeOpen(false); };
    document.addEventListener("mousedown", h);
    return () => document.removeEventListener("mousedown", h);
  }, []);

  const send = (text) => {
    const q = text || input.trim();
    if (!q) return;
    setInput("");
    setMessages(p => [...p, { id:Date.now(), role:"user", text:q }]);
    setIsTyping(true);
    setTimeout(() => {
      setIsTyping(false);
      setMessages(p => [...p, {
        id:Date.now()+1, role:"assistant",
        text: lang==="de"
          ? "Ich habe deine Bibliothek durchsucht. Für diese Frage konnte ich begrenzte Belege finden – ich empfehle, weitere Quellen hinzuzufügen."
          : "I searched your library. Limited evidence was found – consider adding more sources.",
        confidence:32, confidenceLabel:"Mittlere Sicherheit", confidenceLevel:"mid",
        sources:[], sourceCount:"none", feedback:null,
        warning:"Nur ein teilweiser Beleg in deinen Quellen gefunden.",
        conflictWarning:false,
      }]);
    }, 1400);
  };

  const setFeedback = (id, type) => {
    setMessages(p => p.map(m => m.id===id ? {...m, feedback:type} : m));
  };

  const visibleMsgs = histSearch
    ? messages.filter(m => m.text?.toLowerCase().includes(histSearch.toLowerCase()))
    : messages;

  const btnBase = { fontSize:11, border:"1px solid #e2e8f0", borderRadius:8,
    padding:"4px 10px", cursor:"pointer", fontFamily:"inherit", background:"#fff", color:"#475569" };
  const btnActive = { ...btnBase, background:"#eff6ff", color:"#2563eb", borderColor:"#bfdbfe" };

  return (
    <div style={{ display:"flex", flexDirection:"column", height:"100%", position:"relative", background:"#f8fafc" }}>

      {/* ── Header ── */}
      <div style={{ display:"flex", alignItems:"center", gap:10, padding:"12px 16px",
        background:"#fff", borderBottom:"1px solid #e2e8f0", flexWrap:"wrap", gap:8 }}>
        <div style={{ width:32, height:32, borderRadius:10, background:"#2563eb",
          display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
          <IcMsg size={15} color="#fff" />
        </div>
        <div>
          <p style={{ fontSize:14, fontWeight:500, color:"#1e293b" }}>KI-Chat</p>
          <p style={{ fontSize:11, color:"#94a3b8" }}>durchsucht nur deine lokalen PDFs</p>
        </div>

        {/* Controls */}
        <div style={{ marginLeft:"auto", display:"flex", alignItems:"center", gap:6, flexWrap:"wrap" }}>
          {/* History search */}
          <button onClick={() => setShowSearch(s=>!s)}
            style={{ ...showSearch ? btnActive : btnBase, display:"flex", alignItems:"center", gap:4 }}>
            <IcSearch size={11} color="currentColor" /> Verlauf
          </button>

          {/* Lang */}
          <div style={{ display:"flex", gap:2 }}>
            <button onClick={() => setLang("de")} style={lang==="de" ? btnActive : btnBase}>DE</button>
            <button onClick={() => setLang("en")} style={lang==="en" ? btnActive : btnBase}>EN</button>
          </div>

          {/* Answer length */}
          <div style={{ display:"flex", gap:2 }}>
            {[["kurz","K"],["normal","N"],["ausführlich","A"]].map(([v,l]) => (
              <button key={v} onClick={() => setAnsLen(v)} style={ansLen===v ? btnActive : btnBase}>{l}</button>
            ))}
          </div>

          {/* Cite style */}
          <div style={{ display:"flex", gap:2 }}>
            {["apa","fußnote"].map(v => (
              <button key={v} onClick={() => setCitStyle(v)} style={citStyle===v ? btnActive : btnBase}>
                {v==="apa" ? "APA" : "Fußn."}
              </button>
            ))}
          </div>

          {/* Scope */}
          <div style={{ position:"relative" }} ref={scopeRef}>
            <button onClick={() => setScopeOpen(s=>!s)}
              style={{ ...btnBase, display:"flex", alignItems:"center", gap:5 }}>
              <IcLayers size={11} color="#64748b" />
              <span style={{ maxWidth:90, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{scope}</span>
              <IcChevDown size={10} color="#94a3b8" />
            </button>
            {scopeOpen &&
              <div style={{ position:"absolute", right:0, top:"calc(100% + 4px)", background:"#fff",
                border:"1px solid #e2e8f0", borderRadius:10, boxShadow:"0 4px 16px rgba(0,0,0,0.08)",
                zIndex:10, minWidth:200, overflow:"hidden" }}>
                {SCOPES.map(sc =>
                  <button key={sc} onClick={() => { setScope(sc); setScopeOpen(false); }}
                    style={{ display:"block", width:"100%", textAlign:"left", fontSize:12,
                      padding:"9px 14px", border:"none", fontFamily:"inherit", cursor:"pointer",
                      background: scope===sc ? "#eff6ff" : "transparent",
                      color: scope===sc ? "#2563eb" : "#475569" }}>
                    {sc}
                  </button>)}
              </div>}
          </div>
        </div>
      </div>

      {/* History search bar */}
      {showSearch &&
        <div style={{ padding:"8px 16px", background:"#fff", borderBottom:"1px solid #f1f5f9",
          display:"flex", alignItems:"center", gap:8 }}>
          <IcSearch size={14} color="#94a3b8" />
          <input type="text" placeholder="Chatverlauf durchsuchen…"
            value={histSearch} onChange={e => setHistSearch(e.target.value)}
            style={{ flex:1, border:"none", outline:"none", fontSize:13, color:"#1e293b",
              background:"transparent", fontFamily:"inherit" }} />
          {histSearch && <button onClick={() => setHistSearch("")}
            style={{ background:"none", border:"none", cursor:"pointer" }}>
            <IcX size={14} color="#94a3b8" />
          </button>}
        </div>}

      {/* Messages */}
      <div className="scrollbar-hide"
        style={{ flex:1, overflowY:"auto", padding:"16px 16px 8px" }}>
        {visibleMsgs.map(msg =>
          <ChatMessage key={msg.id} msg={msg}
            onFeedback={setFeedback} onSourceCheck={setModalSrc} citStyle={citStyle} />)}
        {isTyping &&
          <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:12 }}>
            <div style={{ width:28, height:28, borderRadius:"50%", background:"#f1f5f9",
              display:"flex", alignItems:"center", justifyContent:"center" }}>
              <IcLayers size={14} color="#94a3b8" />
            </div>
            <div style={{ background:"#fff", border:"1px solid #e2e8f0",
              borderRadius:"16px 16px 16px 4px", padding:"12px 14px",
              display:"flex", gap:4, alignItems:"center" }}>
              <div className="b1" style={{ width:6, height:6, borderRadius:"50%", background:"#cbd5e1" }} />
              <div className="b2" style={{ width:6, height:6, borderRadius:"50%", background:"#cbd5e1" }} />
              <div className="b3" style={{ width:6, height:6, borderRadius:"50%", background:"#cbd5e1" }} />
            </div>
          </div>}
        <div ref={bottomRef} />
      </div>

      {/* Prompt chips */}
      <div className="scrollbar-hide"
        style={{ padding:"8px 16px", background:"#fff", borderTop:"1px solid #f1f5f9",
          display:"flex", gap:8, overflowX:"auto" }}>
        {PROMPT_CHIPS.map(chip =>
          <button key={chip} onClick={() => send(chip)}
            style={{ flexShrink:0, fontSize:11, color:"#2563eb", border:"1px solid #bfdbfe",
              borderRadius:99, padding:"4px 12px", background:"#fff", cursor:"pointer",
              whiteSpace:"nowrap", fontFamily:"inherit" }}>
            {chip}
          </button>)}
      </div>

      {/* Input */}
      <div style={{ padding:"8px 16px 16px", background:"#fff" }}>
        <div style={{ display:"flex", alignItems:"flex-end", gap:8, background:"#f8fafc",
          border:"1px solid #e2e8f0", borderRadius:16, padding:"8px 10px" }}>
          <textarea value={input} rows={1}
            placeholder={lang==="de" ? "Frage an deine Literatur stellen…" : "Ask your literature a question…"}
            onChange={e => setInput(e.target.value)}
            onKeyDown={e => { if (e.key==="Enter" && !e.shiftKey) { e.preventDefault(); send(); }}}
            style={{ flex:1, background:"transparent", border:"none", outline:"none",
              resize:"none", fontSize:13, color:"#1e293b", fontFamily:"inherit",
              lineHeight:1.5, maxHeight:80 }} />
          <button onClick={() => send()} disabled={!input.trim()}
            style={{ flexShrink:0, width:32, height:32, borderRadius:10, border:"none",
              background: input.trim() ? "#2563eb" : "#e2e8f0", display:"flex",
              alignItems:"center", justifyContent:"center", cursor: input.trim() ? "pointer" : "default",
              marginBottom:2 }}>
            <IcSend size={14} color={input.trim() ? "#fff" : "#94a3b8"} />
          </button>
        </div>
        <p style={{ textAlign:"center", fontSize:11, color:"#94a3b8", marginTop:6 }}>
          Durchsucht: {scope} · Sprache: {lang.toUpperCase()} · Länge: {ansLen} · Stil: {citStyle.toUpperCase()}
        </p>
      </div>

      {modalSrc && <SourceModal source={modalSrc} onClose={() => setModalSrc(null)} />}
    </div>
  );
}

/* ── App Shell ── */
export default function App() {
  const [page, setPage] = useState("chat");
  const [sidebarOpen, setSidebarOpen] = useState(true);

  const current = NAV.find(n => n.id===page);

  return (
    <div style={{ display:"flex", height:"100vh", background:"#f1f5f9", fontFamily:"'Inter',system-ui,sans-serif" }}>

      {/* Sidebar */}
      <div style={{ width: sidebarOpen ? 220 : 60, flexShrink:0, background:"#fff",
        borderRight:"1px solid #e2e8f0", display:"flex", flexDirection:"column",
        transition:"width 0.2s", overflow:"hidden" }}>

        {/* Logo */}
        <div style={{ padding:"16px 14px", borderBottom:"1px solid #f1f5f9",
          display:"flex", alignItems:"center", gap:10 }}>
          <div style={{ width:32, height:32, borderRadius:10, background:"#2563eb",
            display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
            <IcBookOpen size={16} color="#fff" />
          </div>
          {sidebarOpen && <span style={{ fontSize:15, fontWeight:600, color:"#1e293b", whiteSpace:"nowrap" }}>CiteFlow</span>}
        </div>

        {/* Nav */}
        <nav style={{ flex:1, padding:"10px 8px", display:"flex", flexDirection:"column", gap:2 }}>
          {NAV.map(({ id, label, Icon, active }) => {
            const isActive = page===id;
            return (
              <button key={id}
                onClick={() => active && setPage(id)}
                title={label}
                style={{
                  display:"flex", alignItems:"center", gap:10,
                  padding: sidebarOpen ? "9px 12px" : "9px 14px",
                  borderRadius:10, border:"none", cursor: active ? "pointer" : "not-allowed",
                  background: isActive ? "#eff6ff" : "transparent",
                  color: isActive ? "#2563eb" : active ? "#475569" : "#cbd5e1",
                  fontFamily:"inherit", fontSize:13, fontWeight: isActive ? 500 : 400,
                  width:"100%", textAlign:"left", transition:"background 0.15s",
                  opacity: active ? 1 : 0.5,
                }}>
                <Icon size={17} color={isActive ? "#2563eb" : active ? "#64748b" : "#cbd5e1"} />
                {sidebarOpen && <span style={{ whiteSpace:"nowrap" }}>{label}</span>}
                {sidebarOpen && !active &&
                  <span style={{ marginLeft:"auto", fontSize:9, background:"#f1f5f9",
                    color:"#94a3b8", padding:"1px 6px", borderRadius:99, whiteSpace:"nowrap" }}>
                    bald
                  </span>}
              </button>
            );
          })}
        </nav>

        {/* Collapse btn */}
        <button onClick={() => setSidebarOpen(s=>!s)}
          style={{ margin:"0 8px 12px", padding:"8px 12px", border:"1px solid #e2e8f0",
            borderRadius:10, background:"transparent", cursor:"pointer", display:"flex",
            alignItems:"center", gap:8, color:"#94a3b8", fontSize:12, fontFamily:"inherit" }}>
          <IcChevRight size={14} color="#94a3b8"
            style={{ transform: sidebarOpen ? "rotate(180deg)" : "rotate(0deg)", transition:"transform 0.2s" }} />
          {sidebarOpen && "Einklappen"}
        </button>
      </div>

      {/* Main content */}
      <div style={{ flex:1, display:"flex", flexDirection:"column", overflow:"hidden" }}>
        {/* Top bar */}
        <div style={{ padding:"12px 20px", background:"#fff", borderBottom:"1px solid #e2e8f0",
          display:"flex", alignItems:"center", gap:10 }}>
          <span style={{ fontSize:13, color:"#94a3b8" }}>CiteFlow</span>
          <IcChevRight size={13} color="#cbd5e1" />
          <span style={{ fontSize:13, fontWeight:500, color:"#1e293b" }}>{current?.label}</span>
          {page==="chat" &&
            <span style={{ marginLeft:"auto", fontSize:11, background:"#eff6ff",
              color:"#2563eb", padding:"3px 10px", borderRadius:99, border:"1px solid #bfdbfe" }}>
              Lo-Fi Prototyp · Phase 2
            </span>}
        </div>

        {/* Page */}
        <div style={{ flex:1, overflow:"hidden", display:"flex", flexDirection:"column" }}>
          {page==="chat"    ? <KIChat /> :
           page==="library" ? <PlaceholderPage label="Bibliothek" Icon={IcBookOpen} /> :
           page==="map"     ? <PlaceholderPage label="Knowledge Map" Icon={IcMap} /> :
           page==="cite"    ? <PlaceholderPage label="Zitieren" Icon={IcQuote} /> :
           page==="tasks"   ? <PlaceholderPage label="Aufgabenplaner" Icon={IcStar} /> :
           page==="search"  ? <PlaceholderPage label="Suche" Icon={IcSearch} /> :
                              <PlaceholderPage label="Einstellungen" Icon={IcSettings} />}
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
