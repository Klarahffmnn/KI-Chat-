      display:"flex", alignItems:"center", justifyContent:"center",
      zIndex:50, borderRadius:12, padding:16 }}>
      <div onClick={e=>e.stopPropagation()} style={{
        background:"#fff", borderRadius:16, padding:20, maxWidth:360, width:"100%",
        boxShadow:"0 8px 32px rgba(0,0,0,0.15)" }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:14 }}>
          <span style={{ fontSize:13, fontWeight:500, color:"#1e293b" }}>Originalstelle im PDF</span>
          <button onClick={onClose} style={{ background:"none", border:"none", cursor:"pointer" }}>
            <IcX size={16} color="#94a3b8" />
          </button>
        </div>
        <div style={{ background:"#f8fafc", borderRadius:10, padding:14, marginBottom:12 }}>
          <p style={{ fontSize:11, color:"#94a3b8", marginBottom:3 }}>{source.author} · {source.title} · Seite {source.page}</p>
          <div style={{ background:"#fef9c3", border:"1px solid #fde68a", borderRadius:8, padding:10, marginTop:8 }}>
            <p style={{ fontSize:12, color:"#374151", lineHeight:1.65, fontStyle:"italic" }}>
              „...die kommunikative Vernunft drückt sich zunächst in der vereinigenden Kraft intersubjektiv geteilter Sprache aus, durch die Einverständnis sowohl möglich als auch nötig wird..."
            </p>
            <p style={{ fontSize:10, color:"#92400e", marginTop:6, fontWeight:500 }}>
              ↑ Markierte Textstelle — Seite {source.page}
            </p>
          </div>
        </div>
        <div style={{ display:"flex", gap:8 }}>
          <button onClick={onClose} style={{
            flex:1, fontSize:12, color:"#2563eb", border:"1px solid #bfdbfe",
            borderRadius:10, padding:"9px 0", background:"transparent", cursor:"pointer", fontFamily:"inherit" }}>
            PDF öffnen (S. {source.page})
          </button>
          <button onClick={onClose} style={{
            flex:1, fontSize:12, color:"#475569", border:"1px solid #e2e8f0",
