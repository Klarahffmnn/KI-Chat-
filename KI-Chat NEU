};

/* ── Tooltip ── */
function Tooltip({ tip, children }) {
  return (
    <span className="tooltip-wrap">
      {children}
      <span className="tooltip-box">{tip}</span>
    </span>
  );
}

/* ── Confidence Bar ── */
function ConfidenceBar({ level, label, value, matchCount }) {
  const c = CONF_COLORS[level];
  const tip = `Dieser Wert basiert auf ${matchCount || (level==="high"?4:level==="mid"?2:0)} Übereinstimmungen in deiner Literatur. Klicke auf die Quellen, um den Kontext zu prüfen.`;
  return (
    <Tooltip tip={tip}>
      <div style={{ marginTop:8, padding:"8px 12px", borderRadius:8,
        background:c.bg, border:`1px solid ${c.border}`, cursor:"help", width:"100%" }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:4 }}>
          <span style={{ fontSize:11, fontWeight:500, color:c.text }}>{label}</span>
          <span style={{ fontSize:11, color:c.text }}>{value}%</span>
        </div>
        <div style={{ height:6, borderRadius:3, background:"rgba(255,255,255,0.6)", overflow:"hidden" }}>
          <div style={{ height:"100%", borderRadius:3, background:c.bar, width:`${value}%`, transition:"width 0.7s" }} />
        </div>
      </div>
    </Tooltip>
  );
}

/* ── Source Badge ── */
function SourceBadge({ source, onCheck, style: fmt }) {
  const citation = fmt === "apa"
    ? `${source.author}, ${source.year}, S. ${source.page}`
    : `${source.author} (${source.year}), S. ${source.page}`;
  const tip = `Klicken um die Originalstelle in „${source.title}" auf Seite ${source.page} zu öffnen – Textstelle wird gelb markiert.`;
  return (
    <Tooltip tip={tip}>
      <button onClick={() => onCheck(source)}
        style={{ display:"inline-flex", alignItems:"center", gap:4, fontSize:11,
          padding:"3px 9px", borderRadius:99, background:"#eff6ff", color:"#1d4ed8",
          border:"1px solid #bfdbfe", cursor:"pointer", fontFamily:"inherit" }}>
        <IcFile size={10} color="#1d4ed8" />
        {citation}
        <IcEye size={10} color="#93c5fd" />
      </button>
    </Tooltip>
  );
}

/* ── Source Modal ── */
